# LLM API Keys (users provide their own via the UI, but you can set defaults here)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Firebase (optional for MVP — needed for Firestore persistence)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173

# Generated files output directory
OUTPUT_DIR=./generated
